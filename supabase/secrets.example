# Secrets Supabase — NE PAS mettre dans .env
# Déployer avec : supabase secrets set NOM=valeur

# Comptes Cloudinary (bascule auto si espace libre < taille fichier)
# IMPORTANT : utilisez des guillemets simples autour du JSON entier
# Format correct :
#   [{"cloudName":"account1","apiKey":"xxx","apiSecret":"xxx"},{"cloudName":"account2","apiKey":"yyy","apiSecret":"yyy"}]

# Commande (PowerShell / bash) :
supabase secrets set CLOUDINARY_ACCOUNTS='[{"cloudName":"account1","apiKey":"xxx","apiSecret":"xxx"}]'

# Taille max upload en Mo
supabase secrets set MAX_VIDEO_SIZE_MB=100

# Puis redéployer les fonctions :
# supabase functions deploy prepare-upload
# supabase functions deploy complete-upload
# supabase functions deploy delete-video
# supabase functions deploy storage-status
